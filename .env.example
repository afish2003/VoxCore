# =============================================================
# VoxCore Configuration
# Copy this file to .env and fill in your values.
# All provider swaps happen here - no code changes needed.
# =============================================================


# -------------------------------------------------------------
# Wake Word
# -------------------------------------------------------------
WAKE_ENGINE=porcupine

# Built-in keyword to listen for.
# Free options: jarvis, alexa, computer, hey google, hey siri,
#               grasshopper, bumblebee, terminator, picovoice, porcupine
WAKE_KEYWORD=jarvis

# Detection sensitivity: 0.0 (strict) to 1.0 (permissive)
WAKE_SENSITIVITY=0.5

# Get a free Picovoice access key at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_key_here


# -------------------------------------------------------------
# Speech-to-Text
# -------------------------------------------------------------
STT_PROVIDER=whisper

# Model size: tiny / base / small / medium / large
# Larger = more accurate, slower to load, more RAM
WHISPER_MODEL=small

# Device: cpu or cuda
WHISPER_DEVICE=cpu

# Language code (e.g. "en", "es", "fr") or "auto" for detection
WHISPER_LANG=en


# -------------------------------------------------------------
# LLM
# -------------------------------------------------------------

# Backend selection: ollama (local CPU) or vllm (GPU server)
LLM_BACKEND=ollama

# Assistant persona - edit freely, no code changes needed.
# This is the ONLY place the assistant's behavior is defined.
# python-dotenv supports multi-line values inside double quotes.
#
# Current persona: Executive Cyberpunk Amy
# Direct. Professional. Economical. Calm authority. Faint futuristic edge.
#
# Guardrails baked into the prompt:
#   - Hard 20-word cap enforced by explicit instruction
#   - Verbosity check instruction applied before every response
#   - Banned filler phrases listed explicitly
#   - Tone anchors (examples) lock in delivery without code
LLM_SYSTEM_PROMPT="You are Amy — an executive-tier voice assistant. Direct. Professional. Economical. Calm authority. Faint futuristic edge.

Strict rules:
- Responses under 20 spoken words. Factual answers are one sentence.
- State actions, then deliver results. No commentary between them.
- Never explain your reasoning, process, or internal steps.
- Never mention tools, searches, APIs, or any underlying system.
- Never use filler: Of course, Sure, Certainly, Absolutely, Great question, Happy to help, No problem.
- Never praise the user. Never apologize unless there is an actual failure.
- Sarcasm: rare, understated, precise. Feels like high standards, not humor. Never hostile.
- When you have said it, stop.

Verbosity guardrail: Before every response — remove every word that adds no information.

Tone anchors:
- What time is it? -> 3:42 PM.
- What is today's date? -> Tuesday.
- What is the weather? -> Partly cloudy. High of 63.
- Open Spotify. -> Opening Spotify.
- What is 12 times 15, and open the calculator. -> Opening Calculator. 180.
- Repeated obvious question: Yes. Time has not shifted."

# Generation parameters
LLM_TEMPERATURE=0.6
LLM_TOP_P=0.9
LLM_MAX_TOKENS=200

# Maximum tool-call iterations before giving up and returning a fallback response
LLM_MAX_TOOL_ROUNDS=5

# --- Ollama (local, CPU-friendly) ---
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=120

# --- vLLM (GPU inference server) ---
VLLM_URL=http://127.0.0.1:8000/v1/chat/completions
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_TIMEOUT=60


# -------------------------------------------------------------
# Text-to-Speech
# -------------------------------------------------------------
TTS_PROVIDER=elevenlabs

# ElevenLabs API key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_api_key_here

# Voice ID: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=your_voice_id_here

# Model - eleven_flash_v2_5 is fastest and cheapest
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Voice character (all 0.0 - 1.0)
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY=0.85
ELEVENLABS_STYLE=0.3

# Maximum characters sent per TTS call (cost control)
TTS_MAX_CHARS=300


# -------------------------------------------------------------
# Audio I/O
# -------------------------------------------------------------
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=1024

# VAD: how loud before it counts as speech (0 = always record)
VAD_ENERGY_THRESHOLD=500

# Seconds of silence before recording stops
VAD_SILENCE_DURATION=1.5

# Hard cap on recording length in seconds
RECORD_MAX_DURATION=10.0


# -------------------------------------------------------------
# Logging
# -------------------------------------------------------------
LOG_LEVEL=INFO
